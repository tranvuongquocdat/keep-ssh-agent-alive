#!/usr/bin/env bash
#
# A friendly menu on top of tmux: open, create, and stop long-running
# sessions with arrow keys and Enter. Sessions survive disconnects, so
# closing your laptop won't kill your work.

socket='keep-ssh-agent-alive'
config="${XDG_CONFIG_HOME:-$HOME/.config}/keep-ssh-agent-alive/config"
default_command='claude'
session_prefix='agent'
language='en'
mouse='off'
max_hours='0'
# shellcheck source=/dev/null
[ -f "$config" ] && . "$config"

for dep in tmux fzf; do
  command -v "$dep" >/dev/null 2>&1 || {
    echo "Missing '$dep'. Run install.sh first." >&2
    exit 1
  }
done
[ -t 1 ] || { echo "This needs an interactive terminal." >&2; exit 1; }

# Sessions live on this tool's own tmux server, so the status bar and the F12
# binding below never touch the user's regular tmux setup.
tm() { command tmux -L "$socket" "$@"; }
prog=$(basename "$0")
accent=173 # 256-color approximation of the coral in the design

# --- language: one file per language in lang/, picked by language= ----------
script_dir=$(cd "$(dirname "$0")" && pwd)
data_dir="${XDG_DATA_HOME:-$HOME/.local/share}/keep-ssh-agent-alive"
lang_dir=''
for d in "$script_dir/lang" "$data_dir/lang"; do
  [ -f "$d/en.sh" ] && lang_dir=$d && break
done
[ -n "$lang_dir" ] || { echo "Language files not found. Re-run install.sh." >&2; exit 1; }
# English first as the fallback, then the chosen language on top of it.
# shellcheck source=lang/en.sh
. "$lang_dir/en.sh"
if [ "$language" != 'en' ] && [ -f "$lang_dir/$language.sh" ]; then
  # shellcheck source=/dev/null
  . "$lang_dir/$language.sh"
fi

save_config() {
  local esc
  mkdir -p "$(dirname "$config")"
  esc=$(printf '%s' "$default_command" | sed "s/'/'\\\\''/g")
  printf "language='%s'\ndefault_command='%s'\nsession_prefix='%s'\nmouse='%s'\nmax_hours='%s'\n" \
    "$language" "$esc" "$session_prefix" "$mouse" "$max_hours" >"$config"
}

# --- in-session status bar: the way out is always written on screen ---------
themed=''
ensure_theme() {
  [ -n "$themed" ] && return
  tm list-sessions >/dev/null 2>&1 || return
  themed=1
  tm set -g status on
  tm set -g status-interval 5
  tm set -g status-style 'bg=colour236,fg=colour250'
  tm set -g status-left-length 40
  tm set -g status-right-length 60
  tm set -g status-left "#[fg=colour${accent},bold] ✳ #[fg=colour255]#S #[fg=colour244]· #{?#{pane_start_command},#{pane_start_command},#{pane_current_command}} "
  tm set -g status-right "#[fg=colour${accent},bold]F12#[fg=colour250] $m_return "
  tm set -g window-status-format ''
  tm set -g window-status-current-format ''
  tm bind -T root F12 detach-client
  if [ "$mouse" = 'on' ]; then
    tm set -g mouse on
    for ev in MouseDown1Status MouseDown1StatusLeft MouseDown1StatusRight MouseDown1StatusDefault; do
      tm bind -T root "$ev" detach-client
    done
  fi
}

# tmux target: switch instead of nesting when we're already inside our server
open() {
  ensure_theme
  case ${TMUX:-} in
    */"$socket",*) tm switch-client -t "=$1" ;;
    '') tm attach -t "=$1" ;;
    *) TMUX='' tm attach -t "=$1" ;; # inside someone else's tmux
  esac
}

next_name() {
  local i=1
  while tm has-session -t "=$session_prefix-$i" 2>/dev/null; do i=$((i + 1)); done
  printf '%s-%s' "$session_prefix" "$i"
}

# Sessions past their maximum age are stopped whenever the menu opens.
expire_old_sessions() {
  local now name created
  case $max_hours in '' | 0 | *[!0-9]*) return ;; esac
  now=$(date +%s)
  tm list-sessions -F "#{session_name}	#{session_created}" 2>/dev/null |
    while IFS=$'\t' read -r name created; do
      [ $((now - created)) -gt $((max_hours * 3600)) ] && tm kill-session -t "=$name"
    done
  return 0
}

# One row per session: name, then a status dot and what it is running.
session_rows() {
  tm list-sessions -F "#{session_name}	#{session_attached}" 2>/dev/null |
    while IFS=$'\t' read -r name att; do
      IFS=$'\t' read -r start current < <(
        tm display-message -p -t "=$name" $'#{pane_start_command}\t#{pane_current_command}'
      )
      if [ -n "$start" ]; then
        dot=$'\033[32m●\033[0m' label=${start%% *}
      else
        case $current in
          '' | bash | zsh | sh | fish | dash | ksh) dot=$'\033[2m○\033[0m' label=$m_idle ;;
          *) dot=$'\033[32m●\033[0m' label=$current ;;
        esac
      fi
      [ "${att:-0}" != 0 ] && label="$label · $m_attached"
      printf '%s\t%-14s %s \033[2m%s\033[0m\n' "$name" "$name" "$dot" "$label"
    done
  return 0
}

# --- fzf look & feel ----------------------------------------------------------
fzf_theme=(
  --ansi --no-sort --reverse --cycle --height=100%
  --border=rounded --border-label=" ✳ $prog " --border-label-pos=3
  --pointer='❯' --prompt='❯ '
  --color="fg+:255,bg+:236,hl:$accent,hl+:$accent,pointer:$accent,prompt:$accent"
  --color="border:240,label:$accent,header:245,info:245,spinner:$accent,marker:$accent"
  --color="preview-border:240,preview-label:$accent"
)

export KSA_SOCKET="$socket" KSA_EMPTY="$m_empty" KSA_ALL="$m_stop_all"
# shellcheck disable=SC2016  # fzf expands these at preview time, not us
preview='n={1}; case "$n" in __ALL__) printf "%s\n" "$KSA_ALL" ;;
*) tmux -L "$KSA_SOCKET" capture-pane -pe -t "=$n" 2>/dev/null || printf "%s\n" "$KSA_EMPTY" ;; esac'

notice() { echo "$1"; sleep 1.5; }

# --- 1 · open a running session ------------------------------------------------
open_menu() {
  local rows sel
  rows=$(session_rows)
  [ -z "$rows" ] && { notice "$m_no_sessions"; return; }
  sel=$(printf '%s\n' "$rows" | fzf "${fzf_theme[@]}" \
    --delimiter='\t' --with-nth=2 \
    --border-label=" $m_menu_open " \
    --header "$m_keys_back" --header-first \
    --preview="$preview" --preview-window='right,50%,border-rounded' \
    --preview-label=" $m_preview ") || return
  [ -n "$sel" ] && open "${sel%%$'\t'*}"
}

# --- 2 · create a new session ---------------------------------------------------
create() {
  local name cmd def
  def=$(next_name)
  read -r -p "$m_name_q [$def]: " name </dev/tty
  name=${name:-$def}
  case $name in *[.:]* | '') notice "$m_bad_name"; return ;; esac
  if tm has-session -t "=$name" 2>/dev/null; then
    notice "'$name' $m_exists"; return
  fi
  read -r -p "$m_cmd_q [${default_command:-shell}]: " cmd </dev/tty
  cmd=${cmd:-$default_command}
  # New sessions start in the directory the menu was opened from.
  if [ -n "$cmd" ]; then tm new-session -d -s "$name" -c "$PWD" "$cmd"
  else tm new-session -d -s "$name" -c "$PWD"; fi
  themed='' # a fresh server may have just started; re-apply the theme
  open "$name"
}

# --- 3 · stop sessions (multi-select, or all) -----------------------------------
stop_menu() {
  local rows sel names n a
  rows=$(session_rows)
  [ -z "$rows" ] && { notice "$m_no_sessions"; return; }
  sel=$(printf '__ALL__\t\033[38;5;%sm%s\033[0m\n%s\n' "$accent" "$m_stop_all" "$rows" |
    fzf "${fzf_theme[@]}" --delimiter='\t' --with-nth=2 \
      --multi --bind 'space:toggle' --marker='✓' \
      --border-label=" $m_menu_stop " \
      --header "$m_keys_multi" --header-first \
      --preview="$preview" --preview-window='right,50%,border-rounded' \
      --preview-label=" $m_preview ") || return
  if printf '%s\n' "$sel" | grep -q '^__ALL__'; then
    names=$(tm list-sessions -F '#{session_name}' 2>/dev/null)
  else
    names=$(printf '%s\n' "$sel" | cut -f1)
  fi
  [ -z "$names" ] && return
  n=$(printf '%s\n' "$names" | grep -c .)
  read -r -p "$m_confirm_1 $n $m_confirm_2 " a </dev/tty
  case $a in
    [yY]*) printf '%s\n' "$names" | while read -r s; do tm kill-session -t "=$s"; done ;;
  esac
}

# --- 4 · settings ----------------------------------------------------------------
choose_language() {
  local rows f code name sel
  rows=$(for f in "$lang_dir"/*.sh; do
    code=$(basename "$f" .sh)
    name=$(sed -n "s/^lang_name='\(.*\)'/\1/p" "$f")
    printf '%s\t%s\n' "$code" "${name:-$code}"
  done)
  sel=$(printf '%s\n' "$rows" | fzf "${fzf_theme[@]}" \
    --delimiter='\t' --with-nth=2 \
    --border-label=" $m_set_language " \
    --header "$m_keys_back" --header-first | cut -f1) || return
  [ -n "$sel" ] || return
  language=$sel
  save_config
  exec "$0" # restart so every string reloads in the new language
}

settings_menu() {
  local sel new_cmd h hours_disp
  while true; do
    case $max_hours in '' | 0 | *[!0-9]*) hours_disp=$m_unlimited ;; *) hours_disp="$max_hours $m_hours_unit" ;; esac
    sel=$(printf 'language\t%s — %s\ncommand\t%s — %s\nhours\t%s — %s\nback\t%s\n' \
      "$m_set_language" "$lang_name" \
      "$m_set_command" "${default_command:-shell}" \
      "$m_set_hours" "$hours_disp" \
      "$m_back" |
      fzf "${fzf_theme[@]}" --delimiter='\t' --with-nth=2 \
        --border-label=" $m_menu_settings " \
        --header "$m_keys_back" --header-first | cut -f1) || return
    case $sel in
      language) choose_language ;;
      command)
        read -r -p "$m_set_command ($m_cmd_hint) [${default_command:-shell}]: " new_cmd </dev/tty
        [ -z "$new_cmd" ] && continue
        [ "$new_cmd" = 'shell' ] && new_cmd=''
        default_command=$new_cmd
        save_config
        notice "$m_saved" ;;
      hours)
        read -r -p "$m_hours_q [${max_hours:-0}]: " h </dev/tty
        case $h in
          '') ;;
          *[!0-9]*) notice "$m_bad_name" ;;
          *) max_hours=$h; save_config; notice "$m_saved" ;;
        esac ;;
      back | '') return ;;
    esac
  done
}

# --- main menu ---------------------------------------------------------------------
expire_old_sessions
ensure_theme
while true; do
  choice=$(printf 'open\t1 · %s\nnew\t2 · %s\nstop\t3 · %s\nsettings\t4 · %s\nquit\t5 · %s\n' \
    "$m_menu_open" "$m_menu_new" "$m_menu_stop" "$m_menu_settings" "$m_menu_quit" |
    fzf "${fzf_theme[@]}" --delimiter='\t' --with-nth=2 \
      --header "$m_keys_main" --header-first | cut -f1) || break
  case $choice in
    open) open_menu ;;
    new) create ;;
    stop) stop_menu ;;
    settings) settings_menu ;;
    quit) break ;;
  esac
done
